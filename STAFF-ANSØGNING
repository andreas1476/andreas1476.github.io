<div class="rp-form-wrapper">

<h2>🛡️ test Staff Ansøgning</h2>

<p class="intro">
Staff hjælper med at holde serveren fair og seriøs.
Vi forventer modne og ansvarlige personer.
</p>

<form id="staffForm">

<div class="rp-field">
<label for="discord">Discord navn</label>
<input type="text" id="discord" placeholder="Navn#1234" required>
</div>

<div class="rp-field">
<label for="age">Alder</label>
<input type="number" id="age" placeholder="Fx 18" required>
</div>

<div class="rp-field">
<label for="experience">Tidligere staff erfaring</label>
<textarea id="experience"
placeholder="Har du været staff på andre servere?"
required></textarea>
</div>

<div class="rp-field">
<label for="motivation">Hvorfor vil du være staff?</label>
<textarea id="motivation"
placeholder="Minimum 75 tegn"
required></textarea>
</div>

<div class="rp-field">
<label for="time">Hvor mange timer kan du være aktiv pr uge?</label>
<input type="text" id="time" placeholder="Fx 10-15 timer" required>
</div>

<div class="rp-submit">
<button type="submit">Send staff ansøgning</button>
</div>

<p id="staffStatus"></p>

</form>

</div>


<script>

const webhookURL = "https://discord.com/api/webhooks/1479863435658526981/tw2iMtwmMQsl8MNCAGzBF8zhoW2XkZG8Y3ng9a2omjiJ7qlaGfA-0jwV2mZayD2icFtk";

const form = document.getElementById("staffForm");
const status = document.getElementById("staffStatus");

form.addEventListener("submit", function(e){

e.preventDefault();

const discord = document.getElementById("discord").value;
const age = document.getElementById("age").value;
const experience = document.getElementById("experience").value;
const motivation = document.getElementById("motivation").value;
const time = document.getElementById("time").value;

if(motivation.length < 75){

alert("Din motivation skal være mindst 75 tegn.");
return;

}

fetch(webhookURL, {

method: "POST",

headers: {
"Content-Type": "application/json"
},

body: JSON.stringify({

embeds: [{

title: "🛡️ test Staff Ansøgning",

color: 3447003,

fields: [

{ name: "Discord", value: discord },

{ name: "Alder", value: age, inline: true },

{ name: "Staff erfaring", value: experience },

{ name: "Motivation", value: motivation },

{ name: "Timer pr uge", value: time, inline: true }

],

timestamp: new Date()

}]

})

})

.then(()=>{

status.innerText = "✅ Ansøgning sendt til staff!";
form.reset();

})

.catch(()=>{

status.innerText = "❌ Kunne ikke sende ansøgning.";

});

});

</script>
